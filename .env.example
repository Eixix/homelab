TZ=Europe/Berlin

# Nur hier Hostnames/Domains ändern. YAML bleibt gleich.
DOMAIN_EXTERNAL=betz.coffee
DOMAIN_INTERNAL=home
TRAEFIK_HOST=traefik.${DOMAIN_INTERNAL}
