HOMEPAGE_GID=1003
VAULTWARDEN_UID=1003
VAULTWARDEN_GID=1003
SHLINK_DB_PASSWORD=dummy-shlink-db-password-replace-me
SHLINK_DB_ROOT_PASSWORD=dummy-shlink-db-root-password-replace-me
N8N_UID=1003
N8N_GID=1003
